{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CloudFrontOACOnly",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudfront.amazonaws.com"
      },
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::mystical-frontend-751948409376/*",
      "Condition": {
        "StringEquals": {
          "AWS:SourceArn": "arn:aws:cloudfront::751948409376:distribution/CLOUDFRONT_DIST_ID"
        }
      }
    }
  ]
}
